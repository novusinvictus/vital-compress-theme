{
  "name": "t:sections.header.name",
  "type": "header",
  "sections": {
    "vc-announcement-bar": {
      "type": "vc-announcement-bar",
      "blocks": {
        "ann_guarantee": {
          "type": "announcement",
          "settings": { "text": "30-day money-back guarantee" }
        },
        "ann_shipping": {
          "type": "announcement",
          "settings": { "text": "Free shipping on orders $100+" }
        },
        "ann_sale": {
          "type": "announcement",
          "settings": { "text": "Spring Relief Sale" }
        }
      },
      "block_order": ["ann_guarantee", "ann_shipping", "ann_sale"],
      "settings": {
        "color_scheme": "scheme-4",
        "rotation_seconds": 4,
        "help_link_label": "Help",
        "help_link_url": "/pages/help",
        "track_order_label": "Track Your Order",
        "track_order_url": "/pages/track"
      }
    },
    "vc-header": {
      "type": "vc-header",
      "settings": {
        "logo_text": "VITAL COMPRESS",
        "menu": "main-menu",
        "enable_search": true,
        "enable_country_selector": true
      }
    }
  },
  "order": [
    "vc-announcement-bar",
    "vc-header"
  ]
}
