{%- liquid
  assign review_blocks = section.blocks | where: 'type', 'review'
-%}

{%- style -%}
  #VcCustomerReviews-{{ section.id }} {
    padding: 64px 0;
    background-color: #F8FAF9;
    color: #000000;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr__inner {
    display: flex;
    flex-direction: column;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr__header {
    margin-bottom: 48px;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr__heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: 600;
    color: #000000;
    font-size: 24px;
    line-height: 1.15;
    margin: 0;
    text-align: left;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr__subheading {
    font-family: var(--font-body-family);
    color: rgba(0, 0, 0, 0.7);
    font-size: 16px;
    line-height: 1.5;
    margin: 8px 0 0;
    max-width: 540px;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card {
    display: flex;
    flex-direction: column;
    padding: 16px;
    border-radius: 8px;
    background-color: #EAEEE3;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__top {
    display: flex;
    flex-direction: column;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__stars {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    line-height: 0;
    margin-bottom: 16px;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__star {
    width: 16px;
    height: 16px;
    fill: #000000;
    display: block;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__body {
    font-family: var(--font-body-family);
    font-size: 18px;
    line-height: 1.625;
    color: #000000;
    margin: 0 0 24px;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__attribution {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__avatar-wrap {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    border-radius: 50%;
    overflow: hidden;
    background-color: #FFFFFF;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__avatar-fallback {
    font-family: var(--font-body-family);
    font-size: 14px;
    font-weight: 600;
    color: rgba(0, 0, 0, 0.6);
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__person {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__name {
    font-family: var(--font-body-family);
    font-size: 14px;
    color: #000000;
    margin: 0;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__location {
    font-family: var(--font-body-family);
    font-size: 14px;
    color: rgba(0, 0, 0, 0.7);
    margin: 0;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__product {
    display: flex;
    align-items: center;
    gap: 16px;
    padding-top: 8px;
    border-top: 1px solid #000000;
    text-decoration: none;
    color: inherit;
    margin-top: auto;
    transition: opacity 0.2s ease;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__product:hover {
    opacity: 0.8;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__product-image-wrap {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
    border-radius: 4px;
    overflow: hidden;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__product-image,
  #VcCustomerReviews-{{ section.id }} .vc-cr-card__product-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__product-info {
    flex: 1;
    min-width: 0;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__product-title {
    font-family: var(--font-body-family);
    font-size: 14px;
    font-weight: 500;
    color: #000000;
    margin: 0 0 4px;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__product-price-row {
    display: flex;
    align-items: baseline;
    gap: 8px;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__product-price-current {
    font-family: var(--font-body-family);
    font-size: 14px;
    font-weight: 500;
    color: #000000;
  }

  #VcCustomerReviews-{{ section.id }} .vc-cr-card__product-price-compare {
    font-family: var(--font-body-family);
    font-size: 12px;
    color: #000000;
    text-decoration: line-through;
  }

  @media screen and (min-width: 768px) {
    #VcCustomerReviews-{{ section.id }} .vc-cr-card {
      padding: 24px;
    }

    #VcCustomerReviews-{{ section.id }} .vc-cr__heading {
      font-size: 36px;
    }
  }

  @media screen and (min-width: 1024px) {
    #VcCustomerReviews-{{ section.id }} .vc-cr__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 30px;
    }

    #VcCustomerReviews-{{ section.id }} .vc-cr-card {
      padding: 32px;
    }
  }
{%- endstyle -%}

{%- capture star_svg -%}
  <svg class="vc-cr-card__star" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M16 6.28345C16 6.42478 15.9167 6.57878 15.75 6.74545L12.2593 10.1488L13.086 14.9568C13.0927 15.0015 13.096 15.0661 13.096 15.1495C13.0998 15.2709 13.0645 15.3903 12.9953 15.4901C12.962 15.5361 12.9177 15.573 12.8665 15.5974C12.8152 15.6219 12.7587 15.6331 12.702 15.6301C12.58 15.6301 12.452 15.5915 12.3173 15.5141L8 13.2461L3.68267 15.5155C3.54133 15.5921 3.41333 15.6308 3.298 15.6308C3.16333 15.6308 3.06267 15.5841 2.99533 15.4908C2.9259 15.391 2.89037 15.2716 2.894 15.1501C2.894 15.1115 2.90067 15.0475 2.914 14.9575L3.74067 10.1501L0.240667 6.74612C0.08 6.57212 0 6.41878 0 6.28345C0 6.04678 0.18 5.89878 0.538667 5.84145L5.36533 5.13945L7.52867 0.764784C7.65067 0.50145 7.80733 0.370117 8 0.370117C8.19267 0.370117 8.34933 0.50145 8.47133 0.764784L10.6347 5.13945L15.4613 5.84145C15.8207 5.89878 16 6.04678 16 6.28345Z"/></svg>
{%- endcapture -%}

<div class="vc-customer-reviews scroll-trigger animate--fade-in" id="VcCustomerReviews-{{ section.id }}">
  <div class="vc-cr__inner page-width">
    <div class="vc-cr__header">
      {%- if section.settings.heading != blank -%}
        <h2 class="vc-cr__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="vc-cr__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>

    <div class="vc-cr__grid">
      {%- for block in review_blocks -%}
        {%- assign rating = block.settings.star_rating | default: 5 -%}
        {%- assign linked = block.settings.linked_product -%}
        {%- assign initial = block.settings.name | strip | slice: 0 | upcase -%}
        <article class="vc-cr-card" {{ block.shopify_attributes }}>
          <div class="vc-cr-card__top">
            <div class="vc-cr-card__stars" aria-label="{{ rating }} out of 5 stars">
              {%- for i in (1..rating) -%}{{ star_svg }}{%- endfor -%}
            </div>

            {%- if block.settings.body != blank -%}
              <blockquote class="vc-cr-card__body">"{{ block.settings.body | escape }}"</blockquote>
            {%- endif -%}

            <div class="vc-cr-card__attribution">
              <div class="vc-cr-card__avatar-wrap">
                {%- if block.settings.avatar != blank -%}
                  {{
                    block.settings.avatar
                    | image_url: width: 144
                    | image_tag:
                      widths: '48, 96, 144',
                      sizes: '48px',
                      loading: 'lazy',
                      alt: block.settings.name | default: 'Customer',
                      class: 'vc-cr-card__avatar'
                  }}
                {%- else -%}
                  <span class="vc-cr-card__avatar-fallback" aria-hidden="true">{{ initial | default: '•' }}</span>
                {%- endif -%}
              </div>
              <div class="vc-cr-card__person">
                {%- if block.settings.name != blank -%}
                  <p class="vc-cr-card__name">{{ block.settings.name | escape }}</p>
                {%- endif -%}
                {%- if block.settings.location != blank -%}
                  <p class="vc-cr-card__location">{{ block.settings.location | escape }}</p>
                {%- endif -%}
              </div>
            </div>
          </div>

          {%- if linked != blank -%}
            <a class="vc-cr-card__product" href="{{ linked.url }}">
              <div class="vc-cr-card__product-image-wrap">
                {%- if linked.featured_image != blank -%}
                  {{
                    linked.featured_image
                    | image_url: width: 240
                    | image_tag:
                      widths: '80, 160, 240',
                      sizes: '80px',
                      loading: 'lazy',
                      alt: linked.featured_image.alt | default: linked.title,
                      class: 'vc-cr-card__product-image'
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'vc-cr-card__product-placeholder placeholder-svg' }}
                {%- endif -%}
              </div>
              <div class="vc-cr-card__product-info">
                <p class="vc-cr-card__product-title">{{ linked.title | escape }}</p>
                <div class="vc-cr-card__product-price-row">
                  <span class="vc-cr-card__product-price-current">{{ linked.price | money }}</span>
                  {%- if linked.compare_at_price > linked.price -%}
                    <span class="vc-cr-card__product-price-compare">{{ linked.compare_at_price | money }}</span>
                  {%- endif -%}
                </div>
              </div>
            </a>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "VC Customer Reviews",
  "tag": "section",
  "max_blocks": 6,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See why our customers are so satisfied.."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading (optional)"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "star_rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Review body"
        },
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar (optional)"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location"
        },
        {
          "type": "product",
          "id": "linked_product",
          "label": "Linked product (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VC Customer Reviews",
      "settings": {
        "heading": "See why our customers are so satisfied.."
      },
      "blocks": [
        {
          "type": "review",
          "settings": {
            "star_rating": 5,
