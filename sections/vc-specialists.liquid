{%- style -%}
  #VcSpecialists-{{ section.id }} {
    padding: 48px 0;
    background-color: #F8FAF9;
    color: rgb(var(--color-foreground));
  }

  #VcSpecialists-{{ section.id }} .vc-specialists__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: stretch;
  }

  #VcSpecialists-{{ section.id }} .vc-specialists__content {
    background-color: #FFFFFF;
    border-radius: 6px;
    padding: 24px;
    color: #000000;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  #VcSpecialists-{{ section.id }} .vc-specialists__heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: 600;
    color: #000000;
    font-size: 24px;
    line-height: 1.25;
    margin: 0 0 8px;
  }

  #VcSpecialists-{{ section.id }} .vc-specialists__body {
    font-family: var(--font-body-family);
    color: #000000;
    font-size: 16px;
    line-height: 1.625;
    margin: 0;
  }

  #VcSpecialists-{{ section.id }} .vc-specialists__compare-image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 6px;
    margin-top: 8px;
  }

  #VcSpecialists-{{ section.id }} .vc-specialists__compare-placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: rgba(var(--color-foreground), 0.05);
    border-radius: 6px;
    margin-top: 8px;
  }

  #VcSpecialists-{{ section.id }} .vc-specialists__media {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: 8px;
    overflow: hidden;
    background-color: #F3F4F6;
  }

  #VcSpecialists-{{ section.id }} .vc-specialists__media-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #VcSpecialists-{{ section.id }} .vc-specialists__media-placeholder {
    width: 100%;
    height: 100%;
    background-color: #F3F4F6;
  }

  @media screen and (min-width: 1024px) {
    #VcSpecialists-{{ section.id }} .vc-specialists__inner {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }

    #VcSpecialists-{{ section.id }} .vc-specialists__content {
      padding: 32px;
    }

    #VcSpecialists-{{ section.id }} .vc-specialists__heading {
      font-size: 30px;
    }
  }
{%- endstyle -%}

<div class="vc-specialists scroll-trigger animate--fade-in" id="VcSpecialists-{{ section.id }}">
  <div class="vc-specialists__inner page-width">
    <div class="vc-specialists__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="vc-specialists__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <p class="vc-specialists__body">{{ section.settings.body | escape | newline_to_br }}</p>
      {%- endif -%}

      {%- if section.settings.compare_image != blank -%}
        {{
          section.settings.compare_image
          | image_url: width: 1200
          | image_tag:
            widths: '480, 720, 960, 1200',
            sizes: '(min-width: 1024px) 45vw, 100vw',
            loading: 'lazy',
            alt: section.settings.compare_image.alt | default: 'Comparison',
            class: 'vc-specialists__compare-image'
        }}
      {%- else -%}
        <div class="vc-specialists__compare-placeholder" aria-hidden="true"></div>
      {%- endif -%}
    </div>

    <div class="vc-specialists__media">
      {%- if section.settings.media_image != blank -%}
        {{
          section.settings.media_image
          | image_url: width: 1200
          | image_tag:
            widths: '480, 720, 960, 1200',
            sizes: '(min-width: 1024px) 50vw, 100vw',
            loading: 'lazy',
            alt: section.settings.media_image.alt | default: section.settings.heading,
            class: 'vc-specialists__media-image'
        }}
      {%- else -%}
        <div class="vc-specialists__media-placeholder" aria-hidden="true"></div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "VC Specialists",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Left card"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Physiotherapist-Tested & Recommended"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Inspired by clinical research and real-world testing, Vital Compress sleeves support healthy circulation, joint stability, and pain-free movement across daily activity. Trusted by physiotherapists and orthopaedic specialists for everyday wear and long-term support."
    },
    {
      "type": "image_picker",
      "id": "compare_image",
      "label": "Comparison image",
      "info": "Designed comparison graphic (e.g. Vital Compress vs Generic Sleeves). Recommended 4:3 aspect ratio."
    },
    {
      "type": "header",
      "content": "Right media"
    },
    {
      "type": "image_picker",
      "id": "media_image",
      "label": "Media image",
      "info": "Square 1:1 aspect ratio recommended."
    }
  ],
  "presets": [
    {
      "name": "VC Specialists"
    }
  ]
}
{% endschema %}
