{%- style -%}
  #VcSpecialists-{{ section.id }} {
    padding: 48px 0;
    background-color: #F8FAF9;
    color: rgb(var(--color-foreground));
  }

  #VcSpecialists-{{ section.id }} .vc-specialists__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: stretch;
  }

  #VcSpecialists-{{ section.id }} .vc-specialists__media {
    position: relative;
    aspect-ratio: 1 / 1;
    border-radius: 8px;
    overflow: hidden;
    background-color: #F3F4F6;
  }

  #VcSpecialists-{{ section.id }} .vc-specialists__media-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #VcSpecialists-{{ section.id }} .vc-specialists__media-placeholder {
    width: 100%;
    height: 100%;
    background-color: #F3F4F6;
  }

  @media screen and (min-width: 1024px) {
    #VcSpecialists-{{ section.id }} .vc-specialists__inner {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
  }
{%- endstyle -%}

<div class="vc-specialists scroll-trigger animate--fade-in" id="VcSpecialists-{{ section.id }}">
  <div class="vc-specialists__inner page-width">
    <div class="vc-specialists__media">
      {%- if section.settings.left_image != blank -%}
        {{
          section.settings.left_image
          | image_url: width: 1200
          | image_tag:
            widths: '480, 720, 960, 1200',
            sizes: '(min-width: 1024px) 50vw, 100vw',
            loading: 'lazy',
            alt: section.settings.left_image.alt | default: 'Physiotherapist-tested',
            class: 'vc-specialists__media-image'
        }}
      {%- else -%}
        <div class="vc-specialists__media-placeholder" aria-hidden="true"></div>
      {%- endif -%}
    </div>

    <div class="vc-specialists__media">
      {%- if section.settings.right_image != blank -%}
        {{
          section.settings.right_image
          | image_url: width: 1200
          | image_tag:
            widths: '480, 720, 960, 1200',
            sizes: '(min-width: 1024px) 50vw, 100vw',
            loading: 'lazy',
            alt: section.settings.right_image.alt | default: '',
            class: 'vc-specialists__media-image'
        }}
      {%- else -%}
        <div class="vc-specialists__media-placeholder" aria-hidden="true"></div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "VC Specialists",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "left_image",
      "label": "Left image",
      "info": "Square 1:1 aspect ratio recommended."
    },
    {
      "type": "image_picker",
      "id": "right_image",
      "label": "Right image",
      "info": "Square 1:1 aspect ratio recommended."
    }
  ],
  "presets": [
    {
      "name": "VC Specialists"
    }
  ]
}
{% endschema %}
