{%- style -%}
  #VcMission-{{ section.id }} {
    padding: 56px 0;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    text-align: center;
  }

  #VcMission-{{ section.id }} .vc-mission__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #VcMission-{{ section.id }} .vc-mission__heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    color: rgb(var(--color-foreground));
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.15;
    margin: 0;
    max-width: 880px;
  }

  #VcMission-{{ section.id }} .vc-mission__body {
    font-family: var(--font-body-family);
    color: rgba(var(--color-foreground), 0.85);
    font-size: 16px;
    line-height: 1.6;
    margin: 24px 0 0;
    max-width: 720px;
  }

  #VcMission-{{ section.id }} .vc-mission__features {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 32px 16px;
    margin: 48px 0 0;
    padding: 0;
    list-style: none;
    width: 100%;
  }

  #VcMission-{{ section.id }} .vc-mission__feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  #VcMission-{{ section.id }} .vc-mission__icon {
    width: 64px;
    height: 64px;
    object-fit: contain;
    display: block;
  }

  #VcMission-{{ section.id }} .vc-mission__icon-placeholder {
    width: 64px;
    height: 64px;
    background-color: rgba(var(--color-foreground), 0.06);
    border-radius: 999px;
    display: block;
  }

  #VcMission-{{ section.id }} .vc-mission__title {
    font-family: var(--font-heading-family);
    font-weight: 500;
    color: rgb(var(--color-foreground));
    font-size: 18px;
    line-height: 1.3;
    margin: 16px 0 0;
  }

  #VcMission-{{ section.id }} .vc-mission__description {
    font-family: var(--font-body-family);
    color: rgba(var(--color-foreground), 0.7);
    font-size: 14px;
    line-height: 1.5;
    margin: 8px 0 0;
    max-width: 220px;
  }

  @media screen and (min-width: 750px) {
    #VcMission-{{ section.id }} {
      padding: 80px 0;
    }

    #VcMission-{{ section.id }} .vc-mission__body {
      font-size: 18px;
    }

    #VcMission-{{ section.id }} .vc-mission__features {
      grid-template-columns: repeat({{ section.blocks.size | at_least: 1 | at_most: 6 }}, minmax(0, 1fr));
      gap: 32px;
      margin-top: 64px;
    }
  }
{%- endstyle -%}

<div class="vc-mission" id="VcMission-{{ section.id }}">
  <div class="vc-mission__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="vc-mission__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.body != blank -%}
      <p class="vc-mission__body">{{ section.settings.body | escape | newline_to_br }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="vc-mission__features" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <li class="vc-mission__feature" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                {{
                  block.settings.icon
                  | image_url: width: 192
                  | image_tag:
                    widths: '64, 128, 192',
                    sizes: '64px',
                    loading: 'lazy',
                    alt: block.settings.icon.alt | default: block.settings.title | default: '',
                    class: 'vc-mission__icon'
                }}
              {%- else -%}
                <span class="vc-mission__icon-placeholder" aria-hidden="true"></span>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h3 class="vc-mission__title">{{ block.settings.title | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="vc-mission__description">{{ block.settings.description | escape }}</p>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "VC Mission",
  "tag": "section",
  "max_blocks": 6,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Designed for those who refuse to slow down"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Vital Compress sleeves are made from premium bamboo charcoal fibre that breathes with you. Engineered with graduated medical-grade compression, they support tired joints without the bulk or pinch. Comfortable enough for all-day wear, trusted by physiotherapists and orthopaedic specialists across Australia."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (64×64 recommended)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Short supporting copy."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VC Mission",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Premium Bamboo",
            "description": "Antibacterial, hypoallergenic, breathable fibre that wears like a second skin."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Graduated Compression",
            "description": "Medical-grade pressure profile that supports without restricting movement."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "All-Day Comfort",
            "description": "No pinching, no slipping, no need to take it off between activities."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Trusted by Specialists",
            "description": "Recommended by physiotherapists and orthopaedic specialists across Australia."
          }
        }
      ]
    }
  ]
}
{% endschema %}
