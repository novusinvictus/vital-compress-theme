{%- style -%}
  #VcMission-{{ section.id }} {
    padding: var(--vc-section-py) 0;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
  }

  #VcMission-{{ section.id }} .vc-mission__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: stretch;
  }

  #VcMission-{{ section.id }} .vc-mission__media {
    aspect-ratio: 1 / 1;
    border-radius: 8px;
    overflow: hidden;
    background-color: rgba(var(--color-foreground), 0.04);
  }

  #VcMission-{{ section.id }} .vc-mission__media-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #VcMission-{{ section.id }} .vc-mission__media-placeholder {
    width: 100%;
    height: 100%;
    background-color: rgba(var(--color-foreground), 0.04);
  }

  #VcMission-{{ section.id }} .vc-mission__content {
    background-color: #FFFFFF;
    border-radius: 8px;
    padding: clamp(24px, 5vw, 48px);
    display: flex;
    flex-direction: column;
  }

  #VcMission-{{ section.id }} .vc-mission__heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    color: #000000;
    font-size: clamp(24px, 3vw, 30px);
    line-height: 1.2;
    margin: 0 0 16px;
  }

  #VcMission-{{ section.id }} .vc-mission__body {
    font-family: var(--font-body-family);
    color: #000000;
    font-size: 16px;
    line-height: 1.6;
    margin: 0 0 32px;
  }

  #VcMission-{{ section.id }} .vc-mission__features {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #VcMission-{{ section.id }} .vc-mission__feature {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }

  #VcMission-{{ section.id }} .vc-mission__icon {
    width: 56px;
    height: 56px;
    object-fit: contain;
    display: block;
    flex-shrink: 0;
  }

  #VcMission-{{ section.id }} .vc-mission__icon-placeholder {
    width: 56px;
    height: 56px;
    background-color: rgba(var(--color-foreground), 0.06);
    border-radius: 999px;
    display: block;
    flex-shrink: 0;
  }

  #VcMission-{{ section.id }} .vc-mission__feature-text {
    flex: 1;
    min-width: 0;
  }

  #VcMission-{{ section.id }} .vc-mission__title {
    font-family: var(--font-heading-family);
    font-weight: 600;
    color: #000000;
    font-size: 16px;
    line-height: 1.3;
    margin: 0 0 4px;
  }

  #VcMission-{{ section.id }} .vc-mission__description {
    font-family: var(--font-body-family);
    color: #000000;
    font-size: 16px;
    line-height: 1.5;
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    #VcMission-{{ section.id }} .vc-mission__inner {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
  }
{%- endstyle -%}

<div class="vc-mission scroll-trigger animate--fade-in" id="VcMission-{{ section.id }}">
  <div class="vc-mission__inner page-width">
    <div class="vc-mission__media">
      {%- if section.settings.media_image != blank -%}
        {{
          section.settings.media_image
          | image_url: width: 1200
          | image_tag:
            widths: '480, 720, 960, 1200',
            sizes: '(min-width: 750px) 50vw, 100vw',
            loading: 'lazy',
            alt: section.settings.media_image.alt | default: section.settings.heading,
            class: 'vc-mission__media-image'
        }}
      {%- else -%}
        <div class="vc-mission__media-placeholder" aria-hidden="true"></div>
      {%- endif -%}
    </div>

    <div class="vc-mission__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="vc-mission__heading">{{ section.settings.heading | escape }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <p class="vc-mission__body">{{ section.settings.body | escape | newline_to_br }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="vc-mission__features" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <li class="vc-mission__feature" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  {{
                    block.settings.icon
                    | image_url: width: 168
                    | image_tag:
                      widths: '56, 112, 168',
                      sizes: '56px',
                      loading: 'lazy',
                      alt: block.settings.icon.alt | default: block.settings.title | default: '',
                      class: 'vc-mission__icon'
                  }}
                {%- else -%}
                  <span class="vc-mission__icon-placeholder" aria-hidden="true"></span>
                {%- endif -%}
                <div class="vc-mission__feature-text">
                  {%- if block.settings.title != blank -%}
                    <h3 class="vc-mission__title">{{ block.settings.title | escape }}</h3>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <p class="vc-mission__description">{{ block.settings.description | escape }}</p>
                  {%- endif -%}
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "VC Mission",
  "tag": "section",
  "max_blocks": 6,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "media_image",
      "label": "Media image",
      "info": "Square 1:1 aspect ratio recommended."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Designed for those who refuse to slow down"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Vital Compress sleeves are made from premium bamboo charcoal fibre that breathes with you. Engineered with graduated medical-grade compression, they support tired joints without the bulk or pinch. Comfortable enough for all-day wear, trusted by physiotherapists and orthopaedic specialists across Australia."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon (64×64 recommended)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Short supporting copy."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VC Mission",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Premium Bamboo",
            "description": "Antibacterial, hypoallergenic, breathable fibre that wears like a second skin."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Graduated Compression",
            "description": "Medical-grade pressure profile that supports without restricting movement."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "All-Day Comfort",
            "description": "No pinching, no slipping, no need to take it off between activities."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Trusted by Specialists",
            "description": "Recommended by physiotherapists and orthopaedic specialists across Australia."
          }
        }
      ]
    }
  ]
}
{% endschema %}
