{%- liquid
  assign link_columns = section.blocks | where: 'type', 'link_column'
  assign social_blocks = section.blocks | where: 'type', 'social'
-%}

{%- style -%}
  #VcFooter-{{ section.id }} {
    padding: 56px 0 32px;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
  }

  #VcFooter-{{ section.id }} .vc-footer__inner {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  #VcFooter-{{ section.id }} .vc-footer__columns {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* Brand block */
  #VcFooter-{{ section.id }} .vc-footer__brand {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  #VcFooter-{{ section.id }} .vc-footer__logo {
    max-width: 160px;
    height: auto;
    object-fit: contain;
    display: block;
  }

  #VcFooter-{{ section.id }} .vc-footer__logo-fallback {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    color: rgb(var(--color-foreground));
    font-size: 22px;
    margin: 0;
    letter-spacing: 0.5px;
  }

  #VcFooter-{{ section.id }} .vc-footer__tagline {
    font-family: var(--font-body-family);
    color: rgba(var(--color-foreground), 0.85);
    font-size: 15px;
    line-height: 1.4;
    margin: 0;
  }

  #VcFooter-{{ section.id }} .vc-footer__statement {
    font-family: var(--font-body-family);
    color: rgba(var(--color-foreground), 0.7);
    font-size: 14px;
    line-height: 1.55;
    margin: 0;
    max-width: 320px;
  }

  #VcFooter-{{ section.id }} .vc-footer__social {
    display: flex;
    gap: 12px;
    margin-top: 4px;
  }

  #VcFooter-{{ section.id }} .vc-footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    color: rgb(var(--color-foreground));
    background-color: rgba(var(--color-foreground), 0.1);
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  #VcFooter-{{ section.id }} .vc-footer__social-link:hover {
    background-color: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
  }

  #VcFooter-{{ section.id }} .vc-footer__social-link:focus-visible {
    outline: 2px solid rgb(var(--color-foreground));
    outline-offset: 2px;
  }

  #VcFooter-{{ section.id }} .vc-footer__social-icon {
    width: 20px;
    height: 20px;
    fill: currentColor;
    display: block;
  }

  /* Link columns: details/summary accordion on mobile */
  #VcFooter-{{ section.id }} .vc-footer__col {
    border-top: 1px solid rgba(var(--color-foreground), 0.15);
  }

  #VcFooter-{{ section.id }} .vc-footer__col-summary {
    list-style: none;
    cursor: pointer;
    padding: 16px 0;
    font-family: var(--font-body-family);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: rgb(var(--color-foreground));
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  #VcFooter-{{ section.id }} .vc-footer__col-summary::-webkit-details-marker {
    display: none;
  }

  #VcFooter-{{ section.id }} .vc-footer__col-icon {
    width: 12px;
    height: 12px;
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  #VcFooter-{{ section.id }} .vc-footer__col[open] .vc-footer__col-icon {
    transform: rotate(180deg);
  }

  #VcFooter-{{ section.id }} .vc-footer__col-list {
    list-style: none;
    margin: 0;
    padding: 0 0 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  #VcFooter-{{ section.id }} .vc-footer__col-list a {
    font-family: var(--font-body-family);
    color: rgba(var(--color-foreground), 0.85);
    font-size: 14px;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  #VcFooter-{{ section.id }} .vc-footer__col-list a:hover {
    color: rgb(var(--color-foreground));
    text-decoration: underline;
  }

  /* Newsletter */
  #VcFooter-{{ section.id }} .vc-footer__newsletter {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #VcFooter-{{ section.id }} .vc-footer__newsletter-heading {
    font-family: var(--font-body-family);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: rgb(var(--color-foreground));
    margin: 0;
  }

  #VcFooter-{{ section.id }} .vc-footer__newsletter-copy {
    font-family: var(--font-body-family);
    color: rgba(var(--color-foreground), 0.85);
    font-size: 14px;
    line-height: 1.5;
    margin: 0;
  }

  #VcFooter-{{ section.id }} .vc-footer__newsletter-form {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  #VcFooter-{{ section.id }} .vc-footer__newsletter-input {
    flex: 1 1 200px;
    min-width: 0;
    padding: 12px 16px;
    border: 1px solid rgba(var(--color-foreground), 0.3);
    background-color: rgba(var(--color-foreground), 0.05);
    color: rgb(var(--color-foreground));
    border-radius: 4px;
    font-family: var(--font-body-family);
    font-size: 14px;
  }

  #VcFooter-{{ section.id }} .vc-footer__newsletter-input::placeholder {
    color: rgba(var(--color-foreground), 0.5);
  }

  #VcFooter-{{ section.id }} .vc-footer__newsletter-input:focus {
    outline: 2px solid rgb(var(--color-button));
    outline-offset: 1px;
  }

  #VcFooter-{{ section.id }} .vc-footer__newsletter-button {
    padding: 12px 24px;
    background-color: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    border: 0;
    border-radius: 4px;
    font-family: var(--font-body-family);
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    cursor: pointer;
    transition: filter 0.15s ease;
  }

  #VcFooter-{{ section.id }} .vc-footer__newsletter-button:hover {
    filter: brightness(0.92);
  }

  #VcFooter-{{ section.id }} .vc-footer__newsletter-success {
    font-family: var(--font-body-family);
    color: rgba(var(--color-foreground), 0.85);
    font-size: 14px;
    margin: 0;
  }

  /* Bottom strip */
  #VcFooter-{{ section.id }} .vc-footer__bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding-top: 24px;
    border-top: 1px solid rgba(var(--color-foreground), 0.15);
    text-align: center;
  }

  #VcFooter-{{ section.id }} .vc-footer__copy {
    font-family: var(--font-body-family);
    color: rgba(var(--color-foreground), 0.7);
    font-size: 13px;
    margin: 0;
  }

  #VcFooter-{{ section.id }} .vc-footer__payments {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px;
  }

  #VcFooter-{{ section.id }} .vc-footer__payment {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 24px;
    padding: 4px 8px;
    background-color: rgba(var(--color-foreground), 0.08);
    color: rgb(var(--color-foreground));
    border-radius: 4px;
    font-family: var(--font-body-family);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.5px;
    text-transform: uppercase;
  }

  /* Desktop */
  @media screen and (min-width: 750px) {
    #VcFooter-{{ section.id }} {
      padding: 80px 0 40px;
    }

    #VcFooter-{{ section.id }} .vc-footer__inner {
      gap: 56px;
    }

    #VcFooter-{{ section.id }} .vc-footer__columns {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr 1.5fr;
      gap: 40px;
    }

    /* Disable accordion on desktop */
    #VcFooter-{{ section.id }} .vc-footer__col {
      border-top: 0;
    }

    #VcFooter-{{ section.id }} .vc-footer__col-summary {
      cursor: default;
      padding: 0 0 16px;
      pointer-events: none;
    }

    #VcFooter-{{ section.id }} .vc-footer__col-icon {
      display: none;
    }

    #VcFooter-{{ section.id }} .vc-footer__col-list {
      padding: 0;
    }

    #VcFooter-{{ section.id }} .vc-footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
{%- endstyle -%}

{%- comment -%}
  Force open <details> on desktop via no-JS attribute toggle.
{%- endcomment -%}
<script>
  (function () {
    var mq = window.matchMedia('(min-width: 750px)');
    function syncOpen() {
      document.querySelectorAll('#VcFooter-{{ section.id }} .vc-footer__col').forEach(function (el) {
        if (mq.matches) {
          el.setAttribute('open', '');
        } else {
          el.removeAttribute('open');
        }
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', syncOpen);
    } else {
      syncOpen();
    }
    mq.addEventListener ? mq.addEventListener('change', syncOpen) : mq.addListener(syncOpen);
  })();
</script>

<footer class="vc-footer color-{{ section.settings.color_scheme }} gradient" id="VcFooter-{{ section.id }}">
  <div class="vc-footer__inner page-width">
    <div class="vc-footer__columns">
      {%- comment -%} Brand block {%- endcomment -%}
      <div class="vc-footer__brand">
        {%- assign brand_text = section.settings.logo_text | default: shop.name -%}
        {%- if section.settings.logo_image != blank -%}
          {{
            section.settings.logo_image
            | image_url: width: 480
            | image_tag:
              widths: '160, 320, 480',
              sizes: '160px',
              loading: 'lazy',
              alt: brand_text,
              class: 'vc-footer__logo'
          }}
        {%- else -%}
          <p class="vc-footer__logo-fallback">{{ brand_text | escape }}</p>
        {%- endif -%}

        {%- if section.settings.tagline != blank -%}
          <p class="vc-footer__tagline">{{ section.settings.tagline | escape }}</p>
        {%- endif -%}

        {%- if section.settings.brand_statement != blank -%}
          <p class="vc-footer__statement">{{ section.settings.brand_statement | escape }}</p>
        {%- endif -%}

        {%- if social_blocks.size > 0 -%}
          <div class="vc-footer__social">
            {%- for social in social_blocks -%}
              {%- if social.settings.url != blank -%}
                <a class="vc-footer__social-link" href="{{ social.settings.url }}" aria-label="{{ social.settings.platform | capitalize }}" target="_blank" rel="noopener" {{ social.shopify_attributes }}>
                  {%- case social.settings.platform -%}
                    {%- when 'facebook' -%}
                      <svg class="vc-footer__social-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.51 1.49-3.9 3.78-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12z"/></svg>
                    {%- when 'instagram' -%}
                      <svg class="vc-footer__social-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2.16c3.2 0 3.58 0 4.85.07 1.17.05 1.8.25 2.23.42.56.22.96.48 1.38.9.42.42.68.82.9 1.38.17.42.37 1.06.42 2.23.06 1.27.07 1.65.07 4.85s0 3.58-.07 4.85c-.05 1.17-.25 1.8-.42 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.17-1.06.37-2.23.42-1.27.06-1.65.07-4.85.07s-3.58 0-4.85-.07c-1.17-.05-1.8-.25-2.23-.42-.56-.22-.96-.48-1.38-.9-.42-.42-.68-.82-.9-1.38-.17-.42-.37-1.06-.42-2.23-.06-1.27-.07-1.65-.07-4.85s0-3.58.07-4.85c.05-1.17.25-1.8.42-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.17 1.06-.37 2.23-.42C8.42 2.17 8.8 2.16 12 2.16zm0 5.18a4.66 4.66 0 1 0 0 9.32 4.66 4.66 0 0 0 0-9.32zm0 7.69a3.03 3.03 0 1 1 0-6.06 3.03 3.03 0 0 1 0 6.06zm5.94-7.87a1.09 1.09 0 1 1-2.18 0 1.09 1.09 0 0 1 2.18 0z"/></svg>
                    {%- when 'tiktok' -%}
                      <svg class="vc-footer__social-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.07A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.71a8.16 8.16 0 0 0 4.77 1.52V6.79a4.84 4.84 0 0 1-1.84-.1z"/></svg>
                    {%- when 'youtube' -%}
                      <svg class="vc-footer__social-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.6 3.6 12 3.6 12 3.6s-7.6 0-9.4.5A3 3 0 0 0 .5 6.2C0 8 0 12 0 12s0 4 .5 5.8a3 3 0 0 0 2.1 2.1c1.8.5 9.4.5 9.4.5s7.6 0 9.4-.5a3 3 0 0 0 2.1-2.1c.5-1.8.5-5.8.5-5.8s0-4-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
                    {%- when 'twitter' -%}
                      <svg class="vc-footer__social-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                  {%- endcase -%}
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Link columns {%- endcomment -%}
      {%- for block in link_columns -%}
        <details class="vc-footer__col" {{ block.shopify_attributes }}>
          <summary class="vc-footer__col-summary">
            <span>{{ block.settings.heading | default: 'Links' | escape }}</span>
            <svg class="vc-footer__col-icon" viewBox="0 0 12 8" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M1 1l5 5 5-5" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </summary>
          <ul class="vc-footer__col-list">
            {%- if block.settings.menu != blank -%}
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
              {%- endfor -%}
            {%- else -%}
              <li><a role="link" aria-disabled="true">Select a menu in the editor</a></li>
            {%- endif -%}
          </ul>
        </details>
      {%- endfor -%}

      {%- comment -%} Newsletter {%- endcomment -%}
      <div class="vc-footer__newsletter">
        {%- if section.settings.newsletter_heading != blank -%}
          <h3 class="vc-footer__newsletter-heading">{{ section.settings.newsletter_heading | escape }}</h3>
        {%- endif -%}
        {%- if section.settings.newsletter_copy != blank -%}
          <p class="vc-footer__newsletter-copy">{{ section.settings.newsletter_copy | escape }}</p>
        {%- endif -%}
        {%- form 'customer', class: 'vc-footer__newsletter-form' -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input
            type="email"
            name="contact[email]"
            class="vc-footer__newsletter-input"
            placeholder="Email address"
            aria-label="Email address"
            required
          >
          <button type="submit" class="vc-footer__newsletter-button">Subscribe</button>
          {%- if form.posted_successfully? -%}
            <p class="vc-footer__newsletter-success">Thanks — you're subscribed.</p>
          {%- endif -%}
        {%- endform -%}
      </div>
    </div>

    <div class="vc-footer__bottom">
      <p class="vc-footer__copy">
        {%- if section.settings.copyright_text != blank -%}
          &copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright_text | replace: '©', '' | replace: '&copy;', '' | strip | escape }}
        {%- else -%}
          &copy; {{ 'now' | date: '%Y' }} {{ brand_text | escape }}. All rights reserved.
        {%- endif -%}
      </p>

      {%- if section.settings.show_payment_icons -%}
        <div class="vc-footer__payments" aria-label="Accepted payment methods">
          <span class="vc-footer__payment">Visa</span>
          <span class="vc-footer__payment">Mastercard</span>
          <span class="vc-footer__payment">Amex</span>
          <span class="vc-footer__payment">PayPal</span>
          <span class="vc-footer__payment">Apple Pay</span>
          <span class="vc-footer__payment">Google Pay</span>
        </div>
      {%- endif -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "VC Footer",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-4"
    },
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image (optional)",
      "info": "Falls back to brand text if not set."
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Brand text",
      "default": "Vital Compress"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Premium bamboo compression for lasting relief"
    },
    {
      "type": "textarea",
      "id": "brand_statement",
      "label": "Brand statement (optional)"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Heading",
      "default": "Stay updated"
    },
    {
      "type": "textarea",
      "id": "newsletter_copy",
      "label": "Copy",
      "default": "Get 10% off your first order plus expert tips on managing joint comfort."
    },
    {
      "type": "header",
      "content": "Bottom strip"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text",
      "info": "Year is auto-prepended.",
      "default": "Vital Compress. All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment method icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link column",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "info": "Configure menus in Online Store > Navigation."
        }
      ]
    },
    {
      "type": "social",
      "name": "Social link",
      "settings": [
        {
          "type": "select",
          "id": "platform",
          "label": "Platform",
          "options": [
            { "value": "facebook", "label": "Facebook" },
            { "value": "instagram", "label": "Instagram" },
            { "value": "tiktok", "label": "TikTok" },
            { "value": "youtube", "label": "YouTube" },
            { "value": "twitter", "label": "Twitter / X" }
          ],
          "default": "instagram"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VC Footer",
      "settings": {
        "color_scheme": "scheme-4",
        "logo_text": "Vital Compress",
        "tagline": "Premium bamboo compression for lasting relief",
        "newsletter_heading": "Stay updated",
        "newsletter_copy": "Get 10% off your first order plus expert tips on managing joint comfort.",
        "copyright_text": "Vital Compress. All rights reserved.",
        "show_payment_icons": true
      },
      "blocks": [
        { "type": "link_column", "settings": { "heading": "Shop" } },
        { "type": "link_column", "settings": { "heading": "Help" } },
        { "type": "link_column", "settings": { "heading": "Company" } },
        { "type": "social", "settings": { "platform": "instagram" } },
        { "type": "social", "settings": { "platform": "facebook" } }
      ]
    }
  ]
}
{% endschema %}
