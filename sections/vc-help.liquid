{%- style -%}
  #VcHelp-{{ section.id }} {
    padding: var(--vc-section-py) 0;
    background-color: var(--vc-soft-tint);
    color: rgb(var(--color-foreground));
    text-align: center;
  }

  #VcHelp-{{ section.id }} .vc-help__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 560px;
    margin: 0 auto;
  }

  #VcHelp-{{ section.id }} .vc-help__icon {
    width: 48px;
    height: 48px;
    object-fit: contain;
    display: block;
  }

  #VcHelp-{{ section.id }} .vc-help__icon-default {
    width: 48px;
    height: 48px;
    color: var(--vc-primary);
    display: block;
  }

  #VcHelp-{{ section.id }} .vc-help__heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    color: rgb(var(--color-foreground));
    font-size: clamp(22px, 3vw, 28px);
    line-height: 1.2;
    margin: 20px 0 0;
  }

  #VcHelp-{{ section.id }} .vc-help__body {
    font-family: var(--font-body-family);
    color: rgba(var(--color-foreground), 0.75);
    font-size: 16px;
    line-height: 1.6;
    margin: 12px 0 0;
  }

  #VcHelp-{{ section.id }} .vc-help__email {
    font-family: var(--font-body-family);
    color: rgba(var(--color-foreground), 0.7);
    font-size: 14px;
    margin: 16px 0 0;
    text-decoration: none;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.3);
    padding-bottom: 1px;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  #VcHelp-{{ section.id }} .vc-help__email:hover {
    color: rgb(var(--color-foreground));
    border-color: rgb(var(--color-foreground));
  }

  #VcHelp-{{ section.id }} .vc-help__email:focus-visible {
    outline: 2px solid var(--vc-primary);
    outline-offset: 2px;
  }

  #VcHelp-{{ section.id }} .vc-help__cta {
    display: inline-block;
    background-color: transparent;
    color: var(--vc-primary);
    font-family: var(--font-body-family);
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 16px 32px;
    border: 1.5px solid var(--vc-primary);
    border-radius: 4px;
    text-decoration: none;
    margin-top: 28px;
    transition: background-color 0.15s ease, color 0.15s ease;
    cursor: pointer;
  }

  #VcHelp-{{ section.id }} .vc-help__cta:hover {
    background-color: var(--vc-primary);
    color: #FFFFFF;
  }

  #VcHelp-{{ section.id }} .vc-help__cta:active {
    transform: translateY(1px);
  }

  #VcHelp-{{ section.id }} .vc-help__cta:focus-visible {
    outline: 2px solid var(--vc-primary);
    outline-offset: 3px;
  }

  #VcHelp-{{ section.id }} .vc-help__cta[aria-disabled='true'] {
    opacity: 0.5;
    cursor: not-allowed;
  }

{%- endstyle -%}

<div class="vc-help color-{{ section.settings.color_scheme }} gradient" id="VcHelp-{{ section.id }}">
  <div class="vc-help__inner page-width">
    {%- if section.settings.icon != blank -%}
      {{
        section.settings.icon
        | image_url: width: 144
        | image_tag:
          widths: '48, 96, 144',
          sizes: '48px',
          loading: 'lazy',
          alt: section.settings.icon.alt | default: 'Help icon',
          class: 'vc-help__icon'
      }}
    {%- else -%}
      <svg class="vc-help__icon-default" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h3 class="vc-help__heading">{{ section.settings.heading | escape }}</h3>
    {%- endif -%}

    {%- if section.settings.body != blank -%}
      <p class="vc-help__body">{{ section.settings.body | escape }}</p>
    {%- endif -%}

    {%- if section.settings.email != blank -%}
      <a class="vc-help__email" href="mailto:{{ section.settings.email | escape }}">{{ section.settings.email | escape }}</a>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <a
        class="vc-help__cta"
        {% if section.settings.cta_url == blank %}
          role="link" aria-disabled="true"
        {% else %}
          href="{{ section.settings.cta_url }}"
        {% endif %}
      >
        {{- section.settings.cta_label | escape -}}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "VC Help Banner",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "image_picker",
      "id": "icon",
      "label": "Icon (48×48 recommended)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Have questions? We are here."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "Our customer care team is available Monday to Friday, 9am to 5pm AEST."
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email address",
      "info": "Used for the mailto: link.",
      "default": "care@vitalcompress.com.au"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "CONTACT US"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "VC Help Banner",
      "settings": {
        "color_scheme": "scheme-2"
      }
    }
  ]
}
{% endschema %}
