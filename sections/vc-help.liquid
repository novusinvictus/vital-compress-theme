{%- style -%}
  #VcHelp-{{ section.id }} {
    padding: var(--vc-section-py-sm) 0;
    background-color: var(--vc-soft-tint);
    color: rgb(var(--color-foreground));
  }

  #VcHelp-{{ section.id }} .vc-help__inner {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    text-align: left;
  }

  #VcHelp-{{ section.id }} .vc-help__text {
    flex: 1 1 auto;
    min-width: 0;
  }

  #VcHelp-{{ section.id }} .vc-help__heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: 600;
    color: rgb(var(--color-foreground));
    font-size: 20px;
    line-height: 1.25;
    margin: 0;
  }

  #VcHelp-{{ section.id }} .vc-help__body {
    margin: 8px 0 0;
  }

  #VcHelp-{{ section.id }} .vc-help__body > p {
    font-family: var(--font-body-family);
    color: rgba(var(--color-foreground), 0.85);
    font-size: 16px;
    line-height: 1.55;
    margin: 0;
  }

  #VcHelp-{{ section.id }} .vc-help__body > p + p {
    margin-top: 4px;
  }

  #VcHelp-{{ section.id }} .vc-help__body strong {
    font-weight: 600;
    color: rgb(var(--color-foreground));
  }

  #VcHelp-{{ section.id }} .vc-help__cta {
    display: inline-block;
    flex-shrink: 0;
    background-color: transparent;
    color: var(--vc-primary);
    font-family: var(--font-heading-family);
    font-size: 16px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 16px 32px;
    border: 1.5px solid var(--vc-primary);
    border-radius: 4px;
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease;
    cursor: pointer;
  }

  #VcHelp-{{ section.id }} .vc-help__cta:hover {
    background-color: var(--vc-primary);
    color: #FFFFFF;
  }

  #VcHelp-{{ section.id }} .vc-help__cta:active {
    transform: translateY(1px);
  }

  #VcHelp-{{ section.id }} .vc-help__cta:focus-visible {
    outline: 2px solid var(--vc-primary);
    outline-offset: 3px;
  }

  #VcHelp-{{ section.id }} .vc-help__cta[aria-disabled='true'] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media screen and (min-width: 750px) {
    #VcHelp-{{ section.id }} .vc-help__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 32px;
    }

    #VcHelp-{{ section.id }} .vc-help__heading {
      font-size: 24px;
    }
  }
{%- endstyle -%}

<div class="vc-help color-{{ section.settings.color_scheme }} gradient" id="VcHelp-{{ section.id }}">
  <div class="vc-help__inner page-width">
    <div class="vc-help__text">
      {%- if section.settings.heading != blank -%}
        <h3 class="vc-help__heading">{{ section.settings.heading | escape }}</h3>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="vc-help__body rte">{{ section.settings.body }}</div>
      {%- endif -%}
    </div>

    {%- if section.settings.cta_label != blank -%}
      <a
        class="vc-help__cta"
        {% if section.settings.cta_url == blank %}
          role="link" aria-disabled="true"
        {% else %}
          href="{{ section.settings.cta_url }}"
        {% endif %}
      >
        {{- section.settings.cta_label | escape -}}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "VC Help Banner",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Do you have any questions?"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "info": "Wrap the office hours portion in <strong> for Hike-style emphasis.",
      "default": "<p>Our customer care team is available <strong>Monday to Friday, 9am to 5pm AEST</strong>.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "CONTACT US"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "VC Help Banner",
      "settings": {
        "color_scheme": "scheme-2"
      }
    }
  ]
}
{% endschema %}
