{%- liquid
  assign platform_blocks = section.blocks | where: 'type', 'platform'
-%}

{%- style -%}
  #VcTrustRatings-{{ section.id }} {
    padding: 48px 16px;
    background-color: var(--vc-background);
    color: #000000;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    max-width: var(--page-width);
    margin: 0 auto;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr__heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: 600;
    color: #000000;
    font-size: 24px;
    line-height: 1.2;
    margin: 0;
    text-align: center;
    max-width: 768px;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr__cards {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    width: 100%;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 16px;
    border-radius: 8px;
    background-color: var(--vc-soft-tint);
    flex: 1;
    min-width: 160px;
    text-align: center;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr-card__logo {
    height: 32px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr-card__platform-text {
    font-family: var(--font-body-family);
    font-size: 18px;
    font-weight: 600;
    color: #000000;
    margin: 0;
    line-height: 32px;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr-card__rating-row {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr-card__rating-text {
    font-family: var(--font-body-family);
    font-size: 14px;
    font-weight: 500;
    color: #000000;
    margin: 0;
    line-height: 1;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr-card__stars {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    line-height: 0;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr-card__star {
    width: 14px;
    height: 14px;
    fill: #EBBF20;
    display: block;
  }

  @media screen and (min-width: 750px) {
    #VcTrustRatings-{{ section.id }} {
      padding: 64px 24px;
    }

    #VcTrustRatings-{{ section.id }} .vc-tr__inner {
      gap: 32px;
    }

    #VcTrustRatings-{{ section.id }} .vc-tr__heading {
      font-size: 36px;
    }

    #VcTrustRatings-{{ section.id }} .vc-tr__cards {
      gap: 32px;
    }

    #VcTrustRatings-{{ section.id }} .vc-tr-card {
      flex: 0 1 auto;
      padding: 16px 48px;
    }
  }
{%- endstyle -%}

{%- capture star_svg -%}
  <svg class="vc-tr-card__star" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M16 6.28345C16 6.42478 15.9167 6.57878 15.75 6.74545L12.2593 10.1488L13.086 14.9568C13.0927 15.0015 13.096 15.0661 13.096 15.1495C13.0998 15.2709 13.0645 15.3903 12.9953 15.4901C12.962 15.5361 12.9177 15.573 12.8665 15.5974C12.8152 15.6219 12.7587 15.6331 12.702 15.6301C12.58 15.6301 12.452 15.5915 12.3173 15.5141L8 13.2461L3.68267 15.5155C3.54133 15.5921 3.41333 15.6308 3.298 15.6308C3.16333 15.6308 3.06267 15.5841 2.99533 15.4908C2.9259 15.391 2.89037 15.2716 2.894 15.1501C2.894 15.1115 2.90067 15.0475 2.914 14.9575L3.74067 10.1501L0.240667 6.74612C0.08 6.57212 0 6.41878 0 6.28345C0 6.04678 0.18 5.89878 0.538667 5.84145L5.36533 5.13945L7.52867 0.764784C7.65067 0.50145 7.80733 0.370117 8 0.370117C8.19267 0.370117 8.34933 0.50145 8.47133 0.764784L10.6347 5.13945L15.4613 5.84145C15.8207 5.89878 16 6.04678 16 6.28345Z"/></svg>
{%- endcapture -%}
<div class="vc-trust-ratings scroll-trigger animate--fade-in" id="VcTrustRatings-{{ section.id }}">
  <div class="vc-tr__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="vc-tr__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="vc-tr__cards">
      {%- for block in platform_blocks -%}
        {%- assign rating = block.settings.rating | default: 5 -%}
        {%- assign platform_name = block.settings.platform_name | default: 'Platform' -%}
        <div class="vc-tr-card" {{ block.shopify_attributes }}>
          {%- if block.settings.logo_image != blank -%}
            {{
              block.settings.logo_image
              | image_url: width: 240
              | image_tag:
                widths: '120, 240',
                sizes: '120px',
                loading: 'lazy',
                alt: platform_name,
                class: 'vc-tr-card__logo'
            }}
          {%- else -%}
            <p class="vc-tr-card__platform-text">{{ platform_name | escape }}</p>
          {%- endif -%}

          <div class="vc-tr-card__rating-row">
            <span class="vc-tr-card__rating-text">Rated {{ rating }}</span>
            <span class="vc-tr-card__stars" aria-label="{{ rating }} out of 5 stars">
              {%- for i in (1..5) -%}{{ star_svg }}{%- endfor -%}
            </span>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "VC Trust Ratings",
  "tag": "section",
  "max_blocks": 4,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Improving over 50,000+ lives with Vital Compress sleeves"
    }
  ],
  "blocks": [
    {
      "type": "platform",
      "name": "Platform",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Logo image (optional)",
          "info": "Falls back to platform name text if not set."
        },
        {
          "type": "text",
          "id": "platform_name",
          "label": "Platform name",
          "default": "Platform"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 0.1,
          "default": 4.8
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VC Trust Ratings",
      "settings": {
        "heading": "Improving over 50,000+ lives with Vital Compress sleeves"
      },
      "blocks": [
        {
          "type": "platform",
          "settings": {
            "platform_name": "Facebook",
            "rating": 4.6
          }
        },
        {
          "type": "platform",
          "settings": {
            "platform_name": "Google",
            "rating": 4.8
          }
        }
      ]
    }
  ]
}
{% endschema %}
