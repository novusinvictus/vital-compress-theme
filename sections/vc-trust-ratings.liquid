{%- liquid
  assign platform_blocks = section.blocks | where: 'type', 'platform'
-%}

{%- style -%}
  #VcTrustRatings-{{ section.id }} {
    padding: 48px 0;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
  }

  #VcTrustRatings-{{ section.id }} .vc-tr__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr__heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    color: rgb(var(--color-foreground));
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.15;
    margin: 0 0 32px;
    text-align: center;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr__cards {
    display: flex;
    flex-direction: column;
    gap: 16px;
    width: 100%;
    max-width: 800px;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    padding: 32px 24px;
    border-radius: 12px;
    background-color: rgba(var(--color-foreground), 0.04);
    text-align: center;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr-card__logo {
    height: 32px;
    width: auto;
    object-fit: contain;
    display: block;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr-card__platform-text {
    font-family: var(--font-body-family);
    font-size: 16px;
    font-weight: 600;
    color: rgb(var(--color-foreground));
    margin: 0;
    line-height: 32px;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr-card__rating {
    font-family: var(--font-body-family);
    font-size: 36px;
    font-weight: 600;
    color: rgb(var(--color-foreground));
    margin: 0;
    line-height: 1;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr-card__stars {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    line-height: 0;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr-card__star {
    width: 16px;
    height: 16px;
    fill: rgb(var(--color-button));
    display: block;
  }

  #VcTrustRatings-{{ section.id }} .vc-tr-card__star--empty {
    fill: rgba(var(--color-foreground), 0.15);
  }

  #VcTrustRatings-{{ section.id }} .vc-tr-card__count {
    font-family: var(--font-body-family);
    font-size: 13px;
    color: rgba(var(--color-foreground), 0.6);
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    #VcTrustRatings-{{ section.id }} {
      padding: 64px 0;
    }

    #VcTrustRatings-{{ section.id }} .vc-tr__cards {
      flex-direction: row;
      gap: 24px;
    }

    #VcTrustRatings-{{ section.id }} .vc-tr-card {
      flex: 1;
    }
  }
{%- endstyle -%}

{%- capture star_svg -%}
  <svg class="vc-tr-card__star" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
{%- endcapture -%}
{%- capture star_svg_empty -%}
  <svg class="vc-tr-card__star vc-tr-card__star--empty" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
{%- endcapture -%}

<div class="vc-trust-ratings color-scheme-1 gradient" id="VcTrustRatings-{{ section.id }}">
  <div class="vc-tr__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="vc-tr__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <div class="vc-tr__cards">
      {%- for block in platform_blocks -%}
        {%- assign rating = block.settings.rating | default: 5 -%}
        {%- assign filled = rating | floor -%}
        {%- assign empty = 5 | minus: filled -%}
        {%- assign platform_name = block.settings.platform_name | default: 'Platform' -%}
        <div class="vc-tr-card" {{ block.shopify_attributes }}>
          {%- if block.settings.logo_image != blank -%}
            {{
              block.settings.logo_image
              | image_url: width: 240
              | image_tag:
                widths: '120, 240',
                sizes: '120px',
                loading: 'lazy',
                alt: platform_name,
                class: 'vc-tr-card__logo'
            }}
          {%- else -%}
            <p class="vc-tr-card__platform-text">{{ platform_name | escape }}</p>
          {%- endif -%}

          <p class="vc-tr-card__rating">{{ rating }}</p>

          <div class="vc-tr-card__stars" aria-label="{{ rating }} out of 5 stars">
            {%- if filled > 0 -%}
              {%- for i in (1..filled) -%}{{ star_svg }}{%- endfor -%}
            {%- endif -%}
            {%- if empty > 0 -%}
              {%- for i in (1..empty) -%}{{ star_svg_empty }}{%- endfor -%}
            {%- endif -%}
          </div>

          {%- if block.settings.review_count != blank -%}
            <p class="vc-tr-card__count">Based on {{ block.settings.review_count | escape }} reviews</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "VC Trust Ratings",
  "tag": "section",
  "max_blocks": 4,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trusted by thousands across Australia"
    }
  ],
  "blocks": [
    {
      "type": "platform",
      "name": "Platform",
      "settings": [
        {
          "type": "image_picker",
          "id": "logo_image",
          "label": "Logo image (optional)"
        },
        {
          "type": "text",
          "id": "platform_name",
          "label": "Platform name",
          "default": "Platform"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Rating",
          "min": 1,
          "max": 5,
          "step": 0.1,
          "default": 4.8
        },
        {
          "type": "text",
          "id": "review_count",
          "label": "Review count",
          "default": "1,200"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VC Trust Ratings",
      "settings": {
        "heading": "Trusted by thousands across Australia"
      },
      "blocks": [
        {
          "type": "platform",
          "settings": {
            "platform_name": "Facebook",
            "rating": 4.6,
            "review_count": "1,847"
          }
        },
        {
          "type": "platform",
          "settings": {
            "platform_name": "Google",
            "rating": 4.8,
            "review_count": "2,394"
          }
        }
      ]
    }
  ]
}
{% endschema %}
