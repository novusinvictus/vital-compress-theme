{%- style -%}
  #VcCollections-{{ section.id }} {
    padding: 56px 0;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
  }

  #VcCollections-{{ section.id }} .vc-collections__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #VcCollections-{{ section.id }} .vc-collections__heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    color: rgb(var(--color-foreground));
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.15;
    margin: 0 0 32px;
    text-align: center;
  }

  #VcCollections-{{ section.id }} .vc-collections__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    width: 100%;
  }

  #VcCollections-{{ section.id }} .vc-tile {
    position: relative;
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 4px;
    background-color: rgba(var(--color-foreground), 0.08);
    text-decoration: none;
    color: #FFFFFF;
    isolation: isolate;
  }

  #VcCollections-{{ section.id }} .vc-tile--empty {
    background-color: rgba(var(--color-button), 0.08);
    color: rgb(var(--color-foreground));
  }

  #VcCollections-{{ section.id }} .vc-tile__placeholder {
    position: absolute;
    inset: 0;
    background-color: rgba(var(--color-button), 0.08);
    z-index: 0;
  }

  #VcCollections-{{ section.id }} .vc-tile__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    z-index: 0;
  }

  #VcCollections-{{ section.id }} .vc-tile__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 35%, rgba(0, 0, 0, 0.4) 100%);
    transition: background 0.4s ease;
    z-index: 1;
  }

  #VcCollections-{{ section.id }} .vc-tile__title {
    position: absolute;
    left: 0;
    bottom: 0;
    z-index: 2;
    font-family: var(--font-heading-family);
    font-weight: 500;
    font-size: 18px;
    line-height: 1.2;
    color: #FFFFFF;
    margin: 0;
    padding: 24px;
  }

  #VcCollections-{{ section.id }} .vc-tile--empty .vc-tile__title {
    color: rgb(var(--color-foreground));
  }

  #VcCollections-{{ section.id }} .vc-tile:hover .vc-tile__image {
    transform: scale(1.04);
  }

  #VcCollections-{{ section.id }} .vc-tile:hover .vc-tile__overlay {
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 25%, rgba(0, 0, 0, 0.55) 100%);
  }

  #VcCollections-{{ section.id }} .vc-tile:focus-visible {
    outline: 2px solid var(--vc-primary);
    outline-offset: 3px;
  }

  #VcCollections-{{ section.id }} .vc-tile[aria-disabled='true'] {
    cursor: not-allowed;
    opacity: 0.7;
  }

  @media screen and (min-width: 750px) {
    #VcCollections-{{ section.id }} {
      padding: 80px 0;
    }

    #VcCollections-{{ section.id }} .vc-collections__heading {
      margin-bottom: 48px;
    }

    #VcCollections-{{ section.id }} .vc-collections__grid {
      grid-template-columns: repeat({{ section.blocks.size | at_least: 1 | at_most: 6 }}, minmax(0, 1fr));
      gap: 24px;
    }

    #VcCollections-{{ section.id }} .vc-tile__title {
      font-size: 22px;
    }
  }
{%- endstyle -%}

<div class="vc-collections" id="VcCollections-{{ section.id }}">
  <div class="vc-collections__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="vc-collections__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="vc-collections__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'tile' -%}
            {%- assign has_tile_image = false -%}
            {%- if block.settings.image != blank -%}{%- assign has_tile_image = true -%}{%- endif -%}
            {%- assign tile_alt = block.settings.image.alt | default: block.settings.title | default: 'Collection tile' -%}
            <a
              class="vc-tile{% unless has_tile_image %} vc-tile--empty{% endunless %}"
              {% if block.settings.link == blank %}
                role="link" aria-disabled="true"
              {% else %}
                href="{{ block.settings.link }}"
              {% endif %}
              {{ block.shopify_attributes }}
            >
              {%- if has_tile_image -%}
                {{
                  block.settings.image
                  | image_url: width: 1200
                  | image_tag:
                    widths: '300, 600, 900, 1200',
                    sizes: '(min-width: 750px) 25vw, 50vw',
                    loading: 'lazy',
                    alt: tile_alt,
                    class: 'vc-tile__image'
                }}
                <span class="vc-tile__overlay" aria-hidden="true"></span>
              {%- else -%}
                <span class="vc-tile__placeholder" aria-hidden="true"></span>
              {%- endif -%}
              {%- if block.settings.title != blank -%}
                <h3 class="vc-tile__title">{{ block.settings.title | escape }}</h3>
              {%- endif -%}
            </a>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "VC Collection Tiles",
  "tag": "section",
  "max_blocks": 6,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore by Body Part"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Collection tile",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Collection title"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VC Collection Tiles",
      "blocks": [
        { "type": "tile", "settings": { "title": "Knee" } },
        { "type": "tile", "settings": { "title": "Ankle" } },
        { "type": "tile", "settings": { "title": "Hand" } },
        { "type": "tile", "settings": { "title": "Foot" } }
      ]
    }
  ]
}
{% endschema %}
