{%- liquid
  if section.index == 1
    assign image_loading = 'eager'
    assign image_fetch_priority = 'high'
  else
    assign image_loading = 'lazy'
    assign image_fetch_priority = 'auto'
  endif

  assign hero_alt_fallback = section.settings.headline | default: 'Hero image'
-%}

{%- style -%}
  #VcHero-{{ section.id }} {
    padding-top: 40px;
    padding-bottom: 0;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    text-align: center;
    overflow-x: clip;
  }

  #VcHero-{{ section.id }} .vc-hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #VcHero-{{ section.id }} .vc-hero__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(var(--color-foreground), 0.06);
    color: rgb(var(--color-foreground));
    padding: 8px 16px;
    border-radius: 999px;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin: 0;
  }

  #VcHero-{{ section.id }} .vc-hero__headline {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    color: rgb(var(--color-foreground));
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.1;
    margin: 24px 0 0;
    letter-spacing: 0;
  }

  #VcHero-{{ section.id }} .vc-hero__subheadline {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    color: rgba(var(--color-foreground), 0.7);
    font-size: 16px;
    line-height: 1.5;
    margin: 20px 0 0;
    max-width: 540px;
  }

  #VcHero-{{ section.id }} .vc-hero__cta {
    display: inline-block;
    background-color: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    font-family: var(--font-body-family);
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 18px 36px;
    border: 0;
    border-radius: 4px;
    text-decoration: none;
    margin-top: 32px;
    transition: filter 0.15s ease, box-shadow 0.15s ease;
    cursor: pointer;
  }

  #VcHero-{{ section.id }} .vc-hero__cta:hover {
    filter: brightness(0.92);
  }

  #VcHero-{{ section.id }} .vc-hero__cta:focus-visible {
    outline: 2px solid rgb(var(--color-button));
    outline-offset: 3px;
  }

  #VcHero-{{ section.id }} .vc-hero__cta[aria-disabled='true'] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  #VcHero-{{ section.id }} .vc-hero__features {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    margin: 48px 0 0;
    padding: 0;
    list-style: none;
    width: 100%;
  }

  #VcHero-{{ section.id }} .vc-hero__feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  #VcHero-{{ section.id }} .vc-hero__feature-icon {
    width: 40px;
    height: 40px;
    object-fit: contain;
    display: block;
  }

  #VcHero-{{ section.id }} .vc-hero__feature-label {
    font-family: var(--font-body-family);
    font-size: 14px;
    font-weight: 500;
    color: rgb(var(--color-foreground));
    line-height: 1.3;
  }

  #VcHero-{{ section.id }} .vc-hero__image-wrap {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-top: 64px;
    line-height: 0;
  }

  #VcHero-{{ section.id }} .vc-hero__image,
  #VcHero-{{ section.id }} .vc-hero__image-placeholder {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  #VcHero-{{ section.id }} .vc-hero__image-placeholder {
    background-color: rgba(var(--color-foreground), 0.05);
  }

  @media screen and (min-width: 750px) {
    #VcHero-{{ section.id }} {
      padding-top: 64px;
    }

    #VcHero-{{ section.id }} .vc-hero__subheadline {
      font-size: 18px;
    }

    #VcHero-{{ section.id }} .vc-hero__features {
      grid-template-columns: repeat({{ section.blocks.size | at_least: 1 | at_most: 6 }}, minmax(0, auto));
      justify-content: center;
      gap: 32px;
    }

    #VcHero-{{ section.id }} .vc-hero__image,
    #VcHero-{{ section.id }} .vc-hero__image-placeholder {
      aspect-ratio: 16 / 7;
    }
  }
{%- endstyle -%}

<div class="vc-hero" id="VcHero-{{ section.id }}">
  <div class="vc-hero__inner page-width">
    {%- if section.settings.badge_text != blank -%}
      <p class="vc-hero__badge">{{ section.settings.badge_text | escape }}</p>
    {%- endif -%}

    {%- if section.settings.headline != blank -%}
      <h1 class="vc-hero__headline">{{ section.settings.headline | escape }}</h1>
    {%- endif -%}

    {%- if section.settings.subheadline != blank -%}
      <p class="vc-hero__subheadline">{{ section.settings.subheadline | escape }}</p>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <a
        class="vc-hero__cta"
        {% if section.settings.cta_link == blank %}
          role="link" aria-disabled="true"
        {% else %}
          href="{{ section.settings.cta_link }}"
        {% endif %}
      >
        {{- section.settings.cta_label | escape -}}
      </a>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="vc-hero__features" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <li class="vc-hero__feature" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                {{
                  block.settings.icon
                  | image_url: width: 120
                  | image_tag:
                    widths: '40, 80, 120',
                    sizes: '40px',
                    loading: 'lazy',
                    alt: block.settings.icon.alt | default: '',
                    class: 'vc-hero__feature-icon'
                }}
              {%- endif -%}
              {%- if block.settings.label != blank -%}
                <span class="vc-hero__feature-label">{{ block.settings.label | escape }}</span>
              {%- endif -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>

  {%- if section.settings.desktop_image != blank or section.settings.mobile_image != blank -%}
    <div class="vc-hero__image-wrap">
      <picture>
        {%- if section.settings.mobile_image != blank -%}
          <source
            media="(max-width: 749px)"
            srcset="
              {{ section.settings.mobile_image | image_url: width: 375 }} 375w,
              {{ section.settings.mobile_image | image_url: width: 750 }} 750w,
              {{ section.settings.mobile_image | image_url: width: 1100 }} 1100w,
              {{ section.settings.mobile_image | image_url: width: 1500 }} 1500w
            "
            sizes="100vw"
          >
        {%- endif -%}
        {%- if section.settings.desktop_image != blank -%}
          {{
            section.settings.desktop_image
            | image_url: width: 3000
            | image_tag:
              widths: '750, 1100, 1500, 2000, 3000',
              sizes: '100vw',
              loading: image_loading,
              fetchpriority: image_fetch_priority,
              alt: section.settings.desktop_image.alt | default: hero_alt_fallback,
              class: 'vc-hero__image'
          }}
        {%- elsif section.settings.mobile_image != blank -%}
          {{
            section.settings.mobile_image
            | image_url: width: 1500
            | image_tag:
              widths: '375, 750, 1100, 1500',
              sizes: '100vw',
              loading: image_loading,
              fetchpriority: image_fetch_priority,
              alt: section.settings.mobile_image.alt | default: hero_alt_fallback,
              class: 'vc-hero__image'
          }}
        {%- endif -%}
      </picture>
    </div>
  {%- else -%}
    <div class="vc-hero__image-wrap">
      <div class="vc-hero__image-placeholder" role="img" aria-label="Hero image placeholder"></div>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "VC Hero",
  "tag": "section",
  "max_blocks": 6,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Eyebrow badge text",
      "default": "Premium Bamboo Compression"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline (H1)",
      "default": "Lasting relief, all-day comfort"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Engineered for those who refuse to slow down"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "SHOP COMPRESSION →"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    },
    {
      "type": "header",
      "content": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop image",
      "info": "Recommended ratio 16:7. Set alt text in Files for accessibility."
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Recommended ratio 4:5. Set alt text in Files for accessibility."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature pill",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image",
          "info": "Square icon, displayed at 40×40."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Feature"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "label": "Feature 1"
          }
        },
        {
          "type": "feature",
          "settings": {
            "label": "Feature 2"
          }
        },
        {
          "type": "feature",
          "settings": {
            "label": "Feature 3"
          }
        },
        {
          "type": "feature",
          "settings": {
            "label": "Feature 4"
          }
        }
      ]
    }
  ]
}
{% endschema %}
