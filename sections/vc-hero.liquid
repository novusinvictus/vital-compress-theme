{%- liquid
  if section.index == 1
    assign image_loading = 'eager'
    assign image_fetch_priority = 'high'
  else
    assign image_loading = 'lazy'
    assign image_fetch_priority = 'auto'
  endif

  assign hero_alt_fallback = section.settings.headline | default: 'Hero image'

  assign has_image = false
  if section.settings.desktop_image != blank or section.settings.mobile_image != blank
    assign has_image = true
  endif
-%}

{%- style -%}
  #VcHero-{{ section.id }} {
    padding: 40px 0 0;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    text-align: center;
    overflow-x: clip;
  }

  #VcHero-{{ section.id }} .vc-hero__inner {
    display: flex;
    flex-direction: column;
  }

  #VcHero-{{ section.id }} .vc-hero__content {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  #VcHero-{{ section.id }} .vc-hero__star-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background-color: rgba(var(--color-foreground), 0.06);
    color: rgb(var(--color-foreground));
    padding: 8px 16px;
    border-radius: 999px;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-size: 13px;
    font-weight: 500;
    margin: 0;
  }

  #VcHero-{{ section.id }} .vc-hero__stars {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    line-height: 0;
  }

  #VcHero-{{ section.id }} .vc-hero__star {
    width: 16px;
    height: 16px;
    fill: rgb(var(--color-button));
    display: block;
  }

  #VcHero-{{ section.id }} .vc-hero__badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(var(--color-foreground), 0.06);
    color: rgb(var(--color-foreground));
    padding: 8px 16px;
    border-radius: 999px;
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin: 16px 0 0;
  }

  #VcHero-{{ section.id }} .vc-hero__headline {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    color: rgb(var(--color-foreground));
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.1;
    margin: 24px 0 0;
    letter-spacing: 0;
  }

  #VcHero-{{ section.id }} .vc-hero__subheadline {
    font-family: var(--font-body-family);
    font-style: var(--font-body-style);
    color: rgba(var(--color-foreground), 0.7);
    font-size: 16px;
    line-height: 1.5;
    margin: 20px 0 0;
    max-width: 540px;
  }

  #VcHero-{{ section.id }} .vc-hero__cta {
    display: inline-block;
    background-color: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    font-family: var(--font-body-family);
    font-size: 14px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 18px 36px;
    border: 0;
    border-radius: 4px;
    text-decoration: none;
    margin-top: 32px;
    transition: filter 0.15s ease, box-shadow 0.15s ease;
    cursor: pointer;
  }

  #VcHero-{{ section.id }} .vc-hero__cta:hover {
    filter: brightness(0.92);
  }

  #VcHero-{{ section.id }} .vc-hero__cta:active {
    filter: brightness(0.85);
    transform: translateY(1px);
  }

  #VcHero-{{ section.id }} .vc-hero__cta:focus-visible {
    outline: 2px solid var(--vc-primary);
    outline-offset: 3px;
  }

  #VcHero-{{ section.id }} .vc-hero__cta[aria-disabled='true'] {
    background-color: rgba(var(--color-foreground), 0.12);
    color: rgba(var(--color-foreground), 0.5);
    cursor: not-allowed;
    pointer-events: none;
  }

  #VcHero-{{ section.id }} .vc-hero__features {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
    margin: 48px 0 0;
    padding: 0;
    list-style: none;
    width: 100%;
  }

  #VcHero-{{ section.id }} .vc-hero__feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  #VcHero-{{ section.id }} .vc-hero__feature-icon {
    width: 32px;
    height: 32px;
    object-fit: contain;
    display: block;
  }

  #VcHero-{{ section.id }} .vc-hero__feature-label {
    font-family: var(--font-body-family);
    font-size: 14px;
    font-weight: 500;
    color: rgb(var(--color-foreground));
    line-height: 1.3;
  }

  #VcHero-{{ section.id }} .vc-hero__media {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-top: 64px;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  #VcHero-{{ section.id }} .vc-hero__picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  #VcHero-{{ section.id }} .vc-hero__image,
  #VcHero-{{ section.id }} .vc-hero__image-placeholder {
    display: block;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    object-position: center;
    transform: none;
    scale: none;
  }

  #VcHero-{{ section.id }} .vc-hero__image-placeholder {
    background-color: rgba(var(--color-foreground), 0.05);
  }

  #VcHero-{{ section.id }}.vc-hero--no-image {
    padding: 40px 0;
  }

  @media screen and (min-width: 750px) {
    #VcHero-{{ section.id }} {
      padding: 64px 0;
      text-align: left;
    }

    #VcHero-{{ section.id }} .vc-hero__inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
    }

    #VcHero-{{ section.id }} .vc-hero__content {
      align-items: flex-start;
      text-align: left;
    }

    #VcHero-{{ section.id }} .vc-hero__subheadline {
      font-size: 18px;
      max-width: none;
    }

    #VcHero-{{ section.id }} .vc-hero__features {
      grid-template-columns: repeat({{ section.blocks.size | at_least: 1 | at_most: 6 }}, minmax(0, auto));
      justify-content: flex-start;
      gap: 24px;
    }

    #VcHero-{{ section.id }} .vc-hero__feature {
      align-items: center;
    }

    #VcHero-{{ section.id }} .vc-hero__media {
      width: 100%;
      margin-left: 0;
      margin-top: 0;
      aspect-ratio: 16 / 10;
      border-radius: 12px;
    }

    #VcHero-{{ section.id }} .vc-hero__image,
    #VcHero-{{ section.id }} .vc-hero__image-placeholder {
      border-radius: 12px;
    }

    #VcHero-{{ section.id }}.vc-hero--no-image {
      padding: 56px 0;
    }

    #VcHero-{{ section.id }}.vc-hero--no-image .vc-hero__inner {
      grid-template-columns: 1fr;
      gap: 0;
      align-items: start;
    }

    #VcHero-{{ section.id }}.vc-hero--no-image .vc-hero__content {
      align-items: center;
      text-align: center;
      max-width: 720px;
      margin: 0 auto;
    }

    #VcHero-{{ section.id }}.vc-hero--no-image .vc-hero__features {
      justify-content: center;
    }

    #VcHero-{{ section.id }}.vc-hero--no-image .vc-hero__cta {
      align-self: center;
    }
  }
{%- endstyle -%}

<div class="vc-hero{% unless has_image %} vc-hero--no-image{% endunless %}" id="VcHero-{{ section.id }}">
  <div class="vc-hero__inner page-width">
    <div class="vc-hero__content">
      {%- if section.settings.star_badge_show and section.settings.star_badge_text != blank -%}
        <p class="vc-hero__star-badge">
          <span class="vc-hero__stars" aria-hidden="true">
            {%- for i in (1..section.settings.star_count) -%}
              <svg class="vc-hero__star" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {%- endfor -%}
          </span>
          <span>{{ section.settings.star_badge_text | escape }}</span>
        </p>
      {%- endif -%}

      {%- if section.settings.badge_text != blank -%}
        <p class="vc-hero__badge">{{ section.settings.badge_text | escape }}</p>
      {%- endif -%}

      {%- if section.settings.headline != blank -%}
        <h1 class="vc-hero__headline">{{ section.settings.headline | escape }}</h1>
      {%- endif -%}

      {%- if section.settings.subheadline != blank -%}
        <p class="vc-hero__subheadline">{{ section.settings.subheadline | escape }}</p>
      {%- endif -%}

      {%- if section.settings.cta_label != blank -%}
        <a
          class="vc-hero__cta"
          {% if section.settings.cta_link == blank %}
            role="link" aria-disabled="true"
          {% else %}
            href="{{ section.settings.cta_link }}"
          {% endif %}
        >
          {{- section.settings.cta_label | escape -}}
        </a>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="vc-hero__features" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <li class="vc-hero__feature" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  {{
                    block.settings.icon
                    | image_url: width: 96
                    | image_tag:
                      widths: '32, 64, 96',
                      sizes: '32px',
                      loading: 'lazy',
                      alt: block.settings.icon.alt | default: '',
                      class: 'vc-hero__feature-icon'
                  }}
                {%- endif -%}
                {%- if block.settings.label != blank -%}
                  <span class="vc-hero__feature-label">{{ block.settings.label | escape }}</span>
                {%- endif -%}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    {%- if has_image -%}
      {%- assign primary_image = section.settings.desktop_image | default: section.settings.mobile_image -%}
      {%- assign hero_alt = primary_image.alt | default: hero_alt_fallback -%}
      <div class="vc-hero__media">
        <picture class="vc-hero__picture">
          {%- if section.settings.mobile_image != blank -%}
            <source
              media="(max-width: 749px)"
              srcset="{{ section.settings.mobile_image | image_url: width: 375 }} 375w, {{ section.settings.mobile_image | image_url: width: 750 }} 750w, {{ section.settings.mobile_image | image_url: width: 1100 }} 1100w, {{ section.settings.mobile_image | image_url: width: 1500 }} 1500w"
              sizes="100vw"
            >
          {%- endif -%}
          <img
            class="vc-hero__image"
            src="{{ primary_image | image_url: width: 1500 }}"
            srcset="{{ primary_image | image_url: width: 750 }} 750w, {{ primary_image | image_url: width: 1100 }} 1100w, {{ primary_image | image_url: width: 1500 }} 1500w, {{ primary_image | image_url: width: 2000 }} 2000w, {{ primary_image | image_url: width: 3000 }} 3000w"
            sizes="(min-width: 750px) 50vw, 100vw"
            width="{{ primary_image.width | default: 3000 }}"
            height="{{ primary_image.height | default: 1250 }}"
            alt="{{ hero_alt | escape }}"
            loading="{{ image_loading }}"
            fetchpriority="{{ image_fetch_priority }}"
          >
        </picture>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "VC Hero",
  "tag": "section",
  "max_blocks": 6,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Social proof badge"
    },
    {
      "type": "checkbox",
      "id": "star_badge_show",
      "label": "Show star rating badge",
      "default": true
    },
    {
      "type": "text",
      "id": "star_badge_text",
      "label": "Star badge text",
      "default": "50,000+ customers in Australia"
    },
    {
      "type": "range",
      "id": "star_count",
      "label": "Number of filled stars",
      "min": 1,
      "max": 5,
      "step": 1,
      "default": 5
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Eyebrow badge text",
      "default": "Premium Bamboo Compression"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline (H1)",
      "default": "Lasting relief, all-day comfort"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Engineered for those who refuse to slow down"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA button label",
      "default": "SHOP COMPRESSION →"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA button link"
    },
    {
      "type": "header",
      "content": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop hero image",
      "info": "Recommended: landscape orientation, 16:10 or wider (e.g. 1920×1200). Set alt text in Files for accessibility."
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile hero image",
      "info": "Recommended: 4:3 landscape (e.g. 1200×900). Set alt text in Files for accessibility."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature pill",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image",
          "info": "Square icon, displayed at 32×32."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Feature"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "label": "Feature 1"
          }
        },
        {
          "type": "feature",
          "settings": {
            "label": "Feature 2"
          }
        },
        {
          "type": "feature",
          "settings": {
            "label": "Feature 3"
          }
        },
        {
          "type": "feature",
          "settings": {
            "label": "Feature 4"
          }
        }
      ]
    }
  ]
}
{% endschema %}
