{%- liquid
  assign logo_blocks = section.blocks | where: 'type', 'logo'
-%}

{%- style -%}
  #VcTrustLogos-{{ section.id }} {
    padding: var(--vc-section-py-sm) 0;
    background-color: var(--vc-soft-tint);
    color: rgb(var(--color-foreground));
    overflow-x: clip;
  }

  #VcTrustLogos-{{ section.id }} .vc-trust-logos__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-align: center;
  }

  #VcTrustLogos-{{ section.id }} .vc-trust-logos__eyebrow {
    font-family: var(--font-body-family);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
  }

  #VcTrustLogos-{{ section.id }} .vc-trust-logos__viewport {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      #000 6%,
      #000 94%,
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      #000 6%,
      #000 94%,
      transparent
    );
  }

  #VcTrustLogos-{{ section.id }} .vc-trust-logos__track {
    display: flex;
    width: max-content;
    animation: vc-trust-logos-scroll-{{ section.id }} 30s linear infinite;
  }

  #VcTrustLogos-{{ section.id }} .vc-trust-logos__viewport:hover .vc-trust-logos__track {
    animation-play-state: paused;
  }

  #VcTrustLogos-{{ section.id }} .vc-trust-logos__list {
    display: flex;
    align-items: center;
    list-style: none;
    padding: 0;
    margin: 0;
    flex-shrink: 0;
  }

  #VcTrustLogos-{{ section.id }} .vc-trust-logos__item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 32px;
    min-height: 40px;
  }

  #VcTrustLogos-{{ section.id }} .vc-trust-logos__image {
    max-height: 32px;
    width: auto;
    object-fit: contain;
    filter: grayscale(100%) opacity(0.7);
    transition: filter 0.2s ease;
    display: block;
  }

  #VcTrustLogos-{{ section.id }} .vc-trust-logos__item:hover .vc-trust-logos__image {
    filter: grayscale(0%) opacity(1);
  }

  #VcTrustLogos-{{ section.id }} .vc-trust-logos__placeholder {
    width: 120px;
    height: 32px;
    background-color: rgba(var(--color-foreground), 0.06);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body-family);
    font-size: 11px;
    color: rgba(var(--color-foreground), 0.4);
  }

  @keyframes vc-trust-logos-scroll-{{ section.id }} {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #VcTrustLogos-{{ section.id }} .vc-trust-logos__track {
      animation: none;
    }
  }
{%- endstyle -%}

<div class="vc-trust-logos scroll-trigger animate--fade-in color-{{ section.settings.color_scheme }} gradient" id="VcTrustLogos-{{ section.id }}">
  <div class="vc-trust-logos__inner">
    {%- if section.settings.eyebrow_text != blank -%}
      <p class="vc-trust-logos__eyebrow">{{ section.settings.eyebrow_text | escape }}</p>
    {%- endif -%}

    {%- if logo_blocks.size > 0 -%}
      <div class="vc-trust-logos__viewport">
        <div class="vc-trust-logos__track">
          <ul class="vc-trust-logos__list" role="list">
            {%- for block in logo_blocks -%}
              {%- assign alt = block.settings.alt_text | default: 'Press logo' -%}
              <li class="vc-trust-logos__item" {{ block.shopify_attributes }}>
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 240
                    | image_tag:
                      widths: '120, 240',
                      sizes: '120px',
                      loading: 'lazy',
                      alt: alt,
                      class: 'vc-trust-logos__image'
                  }}
                {%- else -%}
                  <div class="vc-trust-logos__placeholder">{{ alt | escape }}</div>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
          <ul class="vc-trust-logos__list" role="list" aria-hidden="true">
            {%- for block in logo_blocks -%}
              {%- assign alt = block.settings.alt_text | default: 'Press logo' -%}
              <li class="vc-trust-logos__item">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 240
                    | image_tag:
                      widths: '120, 240',
                      sizes: '120px',
                      loading: 'lazy',
                      alt: '',
                      class: 'vc-trust-logos__image'
                  }}
                {%- else -%}
                  <div class="vc-trust-logos__placeholder">{{ alt | escape }}</div>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "VC Trust Logo Bar",
  "tag": "section",
  "max_blocks": 8,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "Eyebrow text",
      "default": "AS SEEN IN"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Alt text",
          "default": "Press logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VC Trust Logo Bar",
      "settings": {
        "color_scheme": "scheme-2",
        "eyebrow_text": "AS SEEN IN"
      },
      "blocks": [
        { "type": "logo", "settings": { "alt_text": "Press 1" } },
        { "type": "logo", "settings": { "alt_text": "Press 2" } },
        { "type": "logo", "settings": { "alt_text": "Press 3" } },
        { "type": "logo", "settings": { "alt_text": "Press 4" } }
      ]
    }
  ]
}
{% endschema %}
