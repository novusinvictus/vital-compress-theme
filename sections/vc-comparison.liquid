{%- liquid
  assign product_columns = section.blocks | where: 'type', 'product_column'
  assign feature_rows = section.blocks | where: 'type', 'feature_row'
-%}

{%- style -%}
  #VcComparison-{{ section.id }} {
    padding: var(--vc-section-py) 0;
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
  }

  #VcComparison-{{ section.id }} .vc-comparison__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 24px;
  }

  #VcComparison-{{ section.id }} .vc-comparison__heading {
    font-family: var(--font-heading-family);
    font-style: var(--font-heading-style);
    font-weight: var(--font-heading-weight);
    color: rgb(var(--color-foreground));
    font-size: clamp(28px, 4vw, 40px);
    line-height: 1.15;
    margin: 0;
    text-align: center;
  }

  #VcComparison-{{ section.id }} .vc-comparison__subheading {
    font-family: var(--font-body-family);
    color: rgba(var(--color-foreground), 0.7);
    font-size: 16px;
    line-height: 1.5;
    margin: 16px 0 0;
    max-width: 560px;
    text-align: center;
  }

  /* Mobile cards */
  #VcComparison-{{ section.id }} .vc-comparison__cards {
    display: flex;
    flex-direction: column;
    gap: 24px;
    width: 100%;
    margin-top: 40px;
  }

  #VcComparison-{{ section.id }} .vc-comparison__table {
    display: none;
  }

  #VcComparison-{{ section.id }} .vc-card-mobile {
    border: 1px solid rgba(var(--color-foreground), 0.1);
    border-radius: 6px;
    padding: 24px;
    background-color: rgb(var(--color-background));
  }

  #VcComparison-{{ section.id }} .vc-card-mobile__header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 20px;
  }

  #VcComparison-{{ section.id }} .vc-card-mobile__image-wrap {
    width: 64px;
    height: 64px;
    flex-shrink: 0;
    background-color: rgba(var(--color-foreground), 0.04);
    border-radius: 4px;
    overflow: hidden;
  }

  #VcComparison-{{ section.id }} .vc-card-mobile__image,
  #VcComparison-{{ section.id }} .vc-card-mobile__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #VcComparison-{{ section.id }} .vc-card-mobile__title {
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    color: rgb(var(--color-foreground));
    font-size: 18px;
    line-height: 1.2;
    margin: 0;
  }

  #VcComparison-{{ section.id }} .vc-card-mobile__features {
    margin: 0 0 24px;
    padding: 0;
    list-style: none;
  }

  #VcComparison-{{ section.id }} .vc-card-mobile__features li {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 10px 0;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
    font-family: var(--font-body-family);
    font-size: 14px;
    color: rgb(var(--color-foreground));
  }

  #VcComparison-{{ section.id }} .vc-card-mobile__features li:last-child {
    border-bottom: 0;
  }

  #VcComparison-{{ section.id }} .vc-card-mobile__cta {
    display: inline-block;
    background-color: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    font-family: var(--font-body-family);
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 14px 24px;
    border: 0;
    border-radius: 4px;
    text-decoration: none;
    transition: filter 0.15s ease;
  }

  #VcComparison-{{ section.id }} .vc-card-mobile__cta:hover {
    filter: brightness(0.92);
  }

  #VcComparison-{{ section.id }} .vc-card-mobile__cta:active {
    filter: brightness(0.85);
    transform: translateY(1px);
  }

  /* 5-segment progress bar */
  #VcComparison-{{ section.id }} .vc-bar {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    width: 100%;
    max-width: 110px;
  }

  #VcComparison-{{ section.id }} .vc-bar__seg {
    flex: 1;
    min-width: 12px;
    height: 6px;
    border-radius: 1px;
    background-color: rgba(var(--color-foreground), 0.1);
  }

  #VcComparison-{{ section.id }} .vc-bar__seg--filled {
    background-color: rgb(var(--color-button));
  }

  /* Desktop table */
  @media screen and (min-width: 750px) {
    #VcComparison-{{ section.id }} .vc-comparison__cards {
      display: none;
    }

    #VcComparison-{{ section.id }} .vc-comparison__table {
      display: table;
      width: 100%;
      max-width: 1100px;
      margin-top: 48px;
      border-collapse: collapse;
      font-family: var(--font-body-family);
      color: rgb(var(--color-foreground));
    }

    #VcComparison-{{ section.id }} .vc-comparison__table th,
    #VcComparison-{{ section.id }} .vc-comparison__table td {
      padding: 16px 20px;
      text-align: center;
      vertical-align: middle;
      border-bottom: 1px solid rgba(var(--color-foreground), 0.08);
    }

    #VcComparison-{{ section.id }} .vc-comparison__table th:first-child,
    #VcComparison-{{ section.id }} .vc-comparison__table td:first-child {
      text-align: left;
      font-weight: 500;
      width: 30%;
    }

    #VcComparison-{{ section.id }} .vc-product-head {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 12px;
    }

    #VcComparison-{{ section.id }} .vc-product-head__image-wrap {
      width: 80px;
      height: 80px;
      background-color: rgba(var(--color-foreground), 0.04);
      border-radius: 4px;
      overflow: hidden;
    }

    #VcComparison-{{ section.id }} .vc-product-head__image,
    #VcComparison-{{ section.id }} .vc-product-head__placeholder {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    #VcComparison-{{ section.id }} .vc-product-head__title {
      font-family: var(--font-heading-family);
      font-weight: var(--font-heading-weight);
      font-size: 16px;
      color: rgb(var(--color-foreground));
      margin: 0;
    }

    #VcComparison-{{ section.id }} .vc-comparison__table tfoot td {
      border-bottom: 0;
      padding-top: 24px;
    }

    #VcComparison-{{ section.id }} .vc-table-cta {
      display: inline-block;
      background-color: rgb(var(--color-button));
      color: rgb(var(--color-button-text));
      font-family: var(--font-body-family);
      font-size: 12px;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      padding: 12px 20px;
      border: 0;
      border-radius: 4px;
      text-decoration: none;
      transition: filter 0.15s ease;
    }

    #VcComparison-{{ section.id }} .vc-table-cta:hover {
      filter: brightness(0.92);
    }

    #VcComparison-{{ section.id }} .vc-table-cta:active {
      filter: brightness(0.85);
      transform: translateY(1px);
    }

    #VcComparison-{{ section.id }} .vc-table-cta:focus-visible {
      outline: 2px solid var(--vc-primary);
      outline-offset: 3px;
    }
  }
{%- endstyle -%}

{%- comment -%}
  Reusable progress bar snippet rendered inline.
  Pass `score` (0-5) via assign before invoking via capture/include.
{%- endcomment -%}

<div class="vc-comparison scroll-trigger animate--fade-in" id="VcComparison-{{ section.id }}">
  <div class="vc-comparison__inner page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="vc-comparison__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.subheading != blank -%}
      <p class="vc-comparison__subheading">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}

    {%- comment -%} Desktop table {%- endcomment -%}
    {%- if product_columns.size > 0 -%}
      <table class="vc-comparison__table">
        <caption class="visually-hidden">{{ section.settings.heading | escape }}</caption>
        <thead>
          <tr>
            <th scope="col"><span class="visually-hidden">Feature</span></th>
            {%- for col in product_columns -%}
              {%- assign col_product = col.settings.product -%}
              {%- assign col_image = col.settings.image_override | default: col_product.featured_image -%}
              {%- assign col_title = col_product.title | default: 'Product' -%}
              <th scope="col" {{ col.shopify_attributes }}>
                <div class="vc-product-head">
                  <div class="vc-product-head__image-wrap">
                    {%- if col_image != blank -%}
                      {{
                        col_image
                        | image_url: width: 240
                        | image_tag:
                          widths: '80, 160, 240',
                          sizes: '80px',
                          loading: 'lazy',
                          alt: col_image.alt | default: col_title,
                          class: 'vc-product-head__image'
                      }}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'vc-product-head__placeholder placeholder-svg' }}
                    {%- endif -%}
                  </div>
                  <h3 class="vc-product-head__title">{{ col_title | escape }}</h3>
                </div>
              </th>
            {%- endfor -%}
          </tr>
        </thead>
        <tbody>
          {%- for row in feature_rows -%}
            <tr {{ row.shopify_attributes }}>
              <td>{{ row.settings.label | escape }}</td>
              {%- for col_index in (1..product_columns.size) -%}
                {%- assign field_id = 'col_' | append: col_index | append: '_score' -%}
                {%- assign score = row.settings[field_id] | default: 0 -%}
                {%- assign empty_count = 5 | minus: score -%}
                <td>
                  <span class="vc-bar" role="img" aria-label="{{ score }} out of 5">
                    {%- if score > 0 -%}
                      {%- for i in (1..score) -%}<span class="vc-bar__seg vc-bar__seg--filled"></span>{%- endfor -%}
                    {%- endif -%}
                    {%- if empty_count > 0 -%}
                      {%- for i in (1..empty_count) -%}<span class="vc-bar__seg"></span>{%- endfor -%}
                    {%- endif -%}
                  </span>
                </td>
              {%- endfor -%}
            </tr>
          {%- endfor -%}
        </tbody>
        <tfoot>
          <tr>
            <td></td>
            {%- for col in product_columns -%}
              {%- assign col_product = col.settings.product -%}
              <td>
                {%- if col_product != blank -%}
                  <a class="vc-table-cta" href="{{ col_product.url }}">Learn More</a>
                {%- else -%}
                  <a class="vc-table-cta" role="link" aria-disabled="true">Learn More</a>
                {%- endif -%}
              </td>
            {%- endfor -%}
          </tr>
        </tfoot>
      </table>
    {%- endif -%}

    {%- comment -%} Mobile stacked cards {%- endcomment -%}
    {%- if product_columns.size > 0 -%}
      <div class="vc-comparison__cards">
        {%- for col in product_columns -%}
          {%- assign col_product = col.settings.product -%}
          {%- assign col_image = col.settings.image_override | default: col_product.featured_image -%}
          {%- assign col_title = col_product.title | default: 'Product' -%}
          {%- assign col_index = forloop.index -%}
          <article class="vc-card-mobile">
            <div class="vc-card-mobile__header">
              <div class="vc-card-mobile__image-wrap">
                {%- if col_image != blank -%}
                  {{
                    col_image
                    | image_url: width: 192
                    | image_tag:
                      widths: '64, 128, 192',
                      sizes: '64px',
                      loading: 'lazy',
                      alt: col_image.alt | default: col_title,
                      class: 'vc-card-mobile__image'
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'vc-card-mobile__placeholder placeholder-svg' }}
                {%- endif -%}
              </div>
              <h3 class="vc-card-mobile__title">{{ col_title | escape }}</h3>
            </div>
            <ul class="vc-card-mobile__features">
              {%- for row in feature_rows -%}
                {%- assign field_id = 'col_' | append: col_index | append: '_score' -%}
                {%- assign score = row.settings[field_id] | default: 0 -%}
                {%- assign empty_count = 5 | minus: score -%}
                <li>
                  <span>{{ row.settings.label | escape }}</span>
                  <span class="vc-bar" role="img" aria-label="{{ score }} out of 5">
                    {%- if score > 0 -%}
                      {%- for i in (1..score) -%}<span class="vc-bar__seg vc-bar__seg--filled"></span>{%- endfor -%}
                    {%- endif -%}
                    {%- if empty_count > 0 -%}
                      {%- for i in (1..empty_count) -%}<span class="vc-bar__seg"></span>{%- endfor -%}
                    {%- endif -%}
                  </span>
                </li>
              {%- endfor -%}
            </ul>
            {%- if col_product != blank -%}
              <a class="vc-card-mobile__cta" href="{{ col_product.url }}">Learn More</a>
            {%- else -%}
              <a class="vc-card-mobile__cta" role="link" aria-disabled="true">Learn More</a>
            {%- endif -%}
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "VC Product Comparison",
  "tag": "section",
  "max_blocks": 20,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Find Your Perfect Fit"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Compare our compression sleeves at a glance"
    }
  ],
  "blocks": [
    {
      "type": "product_column",
      "name": "Product column",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "image_picker",
          "id": "image_override",
          "label": "Image override (optional)",
          "info": "Falls back to product featured image if not set."
        }
      ]
    },
    {
      "type": "feature_row",
      "name": "Feature row",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Feature label",
          "default": "Feature"
        },
        {
          "type": "range",
          "id": "col_1_score",
          "label": "Score for column 1",
          "min": 0,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "range",
          "id": "col_2_score",
          "label": "Score for column 2",
          "min": 0,
          "max": 5,
          "step": 1,
          "default": 4
        },
        {
          "type": "range",
          "id": "col_3_score",
          "label": "Score for column 3",
          "min": 0,
          "max": 5,
          "step": 1,
          "default": 3
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VC Product Comparison",
      "blocks": [
        { "type": "product_column" },
        { "type": "product_column" },
        { "type": "product_column" },
        { "type": "feature_row", "settings": { "label": "Walking comfort", "col_1_score": 5, "col_2_score": 5, "col_3_score": 5 } },
        { "type": "feature_row", "settings": { "label": "Post-surgery recovery", "col_1_score": 5, "col_2_score": 4, "col_3_score": 3 } },
        { "type": "feature_row", "settings": { "label": "All-day wear", "col_1_score": 5, "col_2_score": 5, "col_3_score": 5 } },
        { "type": "feature_row", "settings": { "label": "Sport activities", "col_1_score": 4, "col_2_score": 5, "col_3_score": 4 } },
        { "type": "feature_row", "settings": { "label": "Travel-friendly", "col_1_score": 4, "col_2_score": 4, "col_3_score": 5 } }
      ]
    }
  ]
}
{% endschema %}
